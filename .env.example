# Enhance API credentials — stored ONLY on the server, never sent to the browser
ENHANCE_API_URL=https://your-enhance-server.com
ENHANCE_API_KEY=your-api-key-here
ENHANCE_ORG_ID=your-org-id

# Proxy server port
PORT=3001

# Safety: read-only mode blocks all write operations (POST, PUT, PATCH, DELETE)
# The proxy will reject any request that could modify data.
# Set to "false" ONLY when you explicitly want to allow changes.
ENHANCE_READ_ONLY=true
